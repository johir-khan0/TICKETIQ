APP_NAME=QueueStorm Warmup API
APP_VERSION=1.0.0
APP_ENV=development
APP_SUMMARY=Classify one customer support ticket into a structured triage response.
APP_CONTACT_NAME=QueueStorm Warmup Maintainers
APP_CONTACT_URL=https://github.com/
APP_LICENSE_NAME=MIT License
APP_LICENSE_IDENTIFIER=MIT
RATE_LIMIT_HEALTH=60/minute
RATE_LIMIT_SORT=30/minute
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,*.onrender.com,*.railway.app
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
MAX_REQUEST_BODY_BYTES=16384
